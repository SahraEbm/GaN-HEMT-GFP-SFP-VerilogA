parameter real		SCALE 		= 1.0		    from (0.0:inf)		        `ATTR(info="SCALING SIZE FACTOR");

parameter real		XL 		    = 0.0 		from (-inf:inf)		        `ATTR(info="OPTICAL OFFSET FOR CHANNEL LENGTH");

parameter real		XW 		    = 0.0 		from (-inf:inf)		        `ATTR(info="OPTICAL OFFSET FOR CHANNEL WIDTH");

