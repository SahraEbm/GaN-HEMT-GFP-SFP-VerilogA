parameter real		N0 		= 1.0		         from [0.0:inf) 		`ATTR(info="WEAK INVERSION FINE TUNING PARAMETER");

parameter real 		VBI 		= 0.0		         from [0.0:inf) 		`ATTR(info="BUILT-IN VOLTAGE DROP-OFF. IF LEFT TO DEFAULT ZERO VALUE, IT IS SET TO THE NOMINAL VALUE OF 3UT HIGHER THAN PHI.");
