parameter real		SIGMAD		= 1.0		from [0.0:inf)		`ATTR(info="SIGMA PARAMETER FOR DRAIN INDUCED BARRIER LOWERING");

//
//***********************************************
//
// INVERSE NARROW CHANNEL EFFECT (3)
//
//***********************************************
//
