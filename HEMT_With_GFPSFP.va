//
// Physical Constants
//
//***********************************************
//
`define type_n       1
`define type_p       -1
`define q           1.60219e-19
`define EP0        8.85418e-12
`define Kb_q        8.617087e-5      // Joule/degree
`define  me         9.11e-31	
//
//***********************************************
//
// 
