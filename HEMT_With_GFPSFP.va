//
//***********************************************
//// ACCESS REGION GEOMETRY
//
//***********************************************
//

parameter real       LARD = 7.0E-6             from [0.0:inf)       `ATTR(type="instance" info="DRAIN ACCESS REGION LENGTH");

parameter real       LARS = 2.0E-6             from [0.0:inf)       `ATTR(type="instance" info="SOURCE ACCESS REGION LENGTH");

parameter real       LSFPD = 10.0E-6              from [0.0:inf)       `ATTR(type="instance" info="GATE-TO-DRAIN SPACING");
 
parameter real       LGS = 2.0E-6               from [0.0:inf)       `ATTR(type="instance" info="GATE-TO-SOURCE SPACING");

//
//***********************************************
//
// MATERIAL AND PHYSICAL PARAMETERS
//
//***********************************************
// 
parameter real       EP_GAN = 8.9*EP0              from (0.0:inf)     `ATTR(info="RELATIVE PERMITTIVITY OF GaN");

parameter real       NC_GAN = (2.3E18)*(1E6)    from [0.0:inf)         `ATTR(info="EFFECTIVE CONDUCTION BAND DENSITY OF STATES FOR GaN [1/m^3]");

parameter real       NV_GAN = (1.89E19)*(1E6)    from [0.0:inf)        `ATTR(info="EFFECTIVE VALENCE BAND DENSITY OF STATES FOR GaN [1/m^3]");

parameter real       NC_ALGAN = (3.5E18)*(1E6)  from [0.0:inf)         `ATTR(info="EFFECTIVE CONDUCTION BAND DENSITY OF STATES FOR AlGaN [1/m^3]");

parameter real       NV_ALGAN = (1.3E19)*(1E6)   from [0.0:inf)        `ATTR(info="EFFECTIVE VALENCE BAND DENSITY OF STATES FOR AlGaN [1/m^3]");

parameter real       NDEP = (1.0E13)*(1E6)           from [0.0:inf)        `ATTR(info="CHANNEL DOPING CONCENTRATION [1/m^3]");

parameter real       CIT = 0.0                            from [0.0:inf)         `ATTR(info="INTERFACE TRAP DENSITY");

//
//***********************************************
//// DIBL AND SUBTHRESHOLD PARAMETERS
//
//***********************************************
//

parameter real       ETA0 = 0.03                       from (-inf:inf)        `ATTR(info="DRAIN-INDUCED BARRIER LOWERING COEFFICIENT");

parameter real       ETAB = -0.01                      from (-inf:inf)         `ATTR(info="BODY-BIAS COEFFICIENT FOR DIBL");

parameter real       PHIN = 0.045                     from (-inf:inf)         `ATTR(info="NONUNIFORM VERTICAL DOPING COEFFICIENT");

parameter real       NFACTOR = 0.0                   from [0.0:inf)          `ATTR(info="SUBTHRESHOLD SLOPE FACTOR");

parameter real       CDSCD = 1.0E-9                   from [0.0:inf)           `ATTR(info="DRAIN-BIAS SENSITIVITY OF SUBTHRESHOLD SLOPE");

parameter real       CDSCB = 0.0                       from [0.0:inf)           `ATTR(info="BODY-BIAS SENSITIVITY OF SUBTHRESHOLD SLOPE");

parameter real       GG = 1.6E-12                     from [0.0:inf)           `ATTR(info="QUANTUM CHARGE POTENTIAL COEFFICIENT");

//
//***********************************************
//
// MOBILITY MODEL PARAMETERS
//
//***********************************************
//

parameter real       U0 = 0.165                         from (0.0)               `ATTR(info="LOW-FIELD MOBILITY");

parameter real       UA = 3.0                           from [0.0:inf)           `ATTR(info="VERTICAL-FIELD MOBILITY DEGRADATION COEFFICIENT");

parameter real       UC = 0.0                           from [0.0:inf)           `ATTR(info="BODY-BIAS MOBILITY DEGRADATION COEFFICIENT");

parameter real       UD = 37.0                        from [0.0:inf)           `ATTR(info="COULOMB SCATTERING COEFFICIENT");

parameter real       EU = 1.0                          from [0.0:inf)            `ATTR(info="MOBILITY DEGRADATION EXPONENT");

parameter real       DE0 = -1.0                       from (-inf:inf)            `ATTR(info="VERTICAL-FIELD MOBILITY POWER FACTOR");

parameter real       ETAVSAT = 0.5                from (-inf:inf)            `ATTR(info="TEMPERATURE COEFFICIENT OF SATURATION VELOCITY");

parameter real       USC = 1.0                        from [0.0:inf)            `ATTR(info="COULOMB SCATTERING SCALING COEFFICIENT");

parameter real       AVDSX = 40.0                  from [5.0:100.0]        `ATTR(info="SMOOTHING PARAMETER FOR EFFECTIVE DRAIN VOLTAGE");

parameter real       LC = 10.0E-9                  from (0.0)                 `ATTR(info="CHARACTERISTIC LENGTH PARAMETER");

parameter real       PTWG = 0.0                    from [0.0:inf)            `ATTR(info="GATE-VOLTAGE COEFFICIENT FOR CHANNEL LENGTH MODULATION");

//
//***********************************************
//// DEVICE TYPE PARAMETERS
//
//***********************************************
//

parameter integer TYPE = type_n                from [-1:1]                 `ATTR(info="DEVICE POLARITY: NFET=1, PFET=-1");

//
//***********************************************
//// SELF-HEATING PARAMETERS
//
//***********************************************
//
parameter real        RTH = 30.0                 from [0.0:inf)             `ATTR(info="THERMAL RESISTANCE [K/W]");

parameter real       CTH = 1.0E-9               from [0.0:inf)              `ATTR(info="THERMAL CAPACITANCE [J/K]");

//
//***********************************************
//
// ACCESS REGION TRANSPORT
//
//***********************************************
//

parameter real     NS0 = 5.0E17*25.0        from [0.0:inf)               `ATTR(info="ACCESS REGION SHEET CHARGE DENSITY");

parameter real     MU0ACC = 0.165           from [0.0:inf)               `ATTR(info="LOW-FIELD ACCESS REGION MOBILITY");

parameter real     VSAT0ACC = 5.0E4       from [0.0:inf)               `ATTR(info="ACCESS REGION SATURATION VELOCITY");

parameter real     RCS = 1.0E-4               from [0.0:inf)               `ATTR(info="SOURCE CONTACT RESISTANCE");

parameter real     RCD = 1.0E-4               from [0.0:inf)               `ATTR(info="DRAIN CONTACT RESISTANCE");

parameter real     KTRS = 0.0                  from [0.0:inf)               `ATTR(info="SOURCE CONTACT TEMPERATURE COEFFICIENT");

parameter real     KTRD = 0.0                 from [0.0:inf)               `ATTR(info="DRAIN CONTACT TEMPERATURE COEFFICIENT");

parameter real     KTH1 = 0.0                 from  [0.0:inf)              `ATTR(info="FIRST-ORDER SELF-HEATING COEFFICIENT");

parameter real     KTH2 = 0.0                from [0.0:inf)               `ATTR(info="SECOND-ORDER SELF-HEATING COEFFICIENT");

parameter real     KTH3 = 0.0                from (-inf:inf)               `ATTR(info="THIRD-ORDER SELF-HEATING COEFFICIENT");

parameter real     GSAR = 2.2                from (-inf:inf)               `ATTR(info="ACCESS REGION GEOMETRY SCALING FACTOR");


//
//***********************************************
// 
// NUMERICAL LIMIT PARAMETERS
//
//***********************************************
//

parameter real      MINL = 1.0E-9          from [0.0:inf)              `ATTR(info="MINIMUM EFFECTIVE LENGTH");

parameter real      MINC = 1.0E-15        from [0.0:inf)               `ATTR(info="MINIMUM CAPACITANCE");

parameter real      MINR = 1.0E-3         from [0.0:inf)               `ATTR(info="MINIMUM RESISTANCE");

//
//***********************************************
//// GATE RESISTANCE PARAMETERS
//
//***********************************************
//
 
parameter real        RGSP = 0.0    from [0.0:inf)     `ATTR(info="GATE RESISTANCE MULTIPLIED BY WIDTH");
parameter real    L    	         = 1E-6 	    from [0.0:inf]; // Channel length [m]
parameter real    W    	     = 3000E-6 	    from [0.0:inf]; // Channel width [m]
parameter real    NF    	     = 1 	              from [1:inf]; // Number of Figures
parameter real    x1         = 30e-9                  from (0:inf);  // AlGaN Layer Thickness (with negative sign)
parameter real    TNOM       = 300  	             from [0.0:inf]; // Temperature [K]
//parameter real    VA             = -5.43          from[-inf:inf];       // V             Threshold Voltage
parameter real    vto             = -3.9                   from[-inf:inf];       // V             Threshold Voltage
parameter real   ep_GaN             =8.9*`EP0        from[-inf:inf];
parameter real    NC_GaN =(2.3e18)*(1e6)     from[-inf:inf]; 
parameter real    NV=(1.89e19)*(1e6)            from[-inf:inf]; 
parameter real    NC=(3.5e18)*(1e6)             from[-inf:inf];    
parameter real    NV_AlGaN=(1.3e19)*(1e6)    from[-inf:inf];   
parameter real     pi = 3.14159                      from[-inf:inf];
parameter real     q = 1.602e-19                    from[-inf:inf];
parameter real     me = 9.11e-31   from[-inf:inf];
parameter real    ETA0             = 0.03          from[-inf:inf];       //                DIBL Coefficeint
parameter real    ETAB             = -0.01          from[-inf:inf];       // 1/V             Body Bias coefficent for DIBL Subthreshold
parameter real    PHIN             = 0.045          from[-inf:inf];       // V             Non uniform vertical doping effect on surface
parameter real    NDEP            = (1.0e13)*(1e6)  from (0.0:inf);      //"1/m^3"   Doping of GaN layer
parameter real    xx         = 0.3          from (0.0:1);   // percentage of Al in AlxxGa(1-xx)N
parameter real    gg      =1.6e-12	    from [0.0:inf];  //Quantum charge potential coefficent
parameter real    E0 	     = 2.0e8; 	    	 	    // Vertical Field Effect [V/m]
parameter real    DE0 	     = -1; 	    	 	    // Vertical Field Effect power factor[V/m]
parameter real    UCRIT 	     = 4.0e6; 	    	 	    // Crutucal Field for velocity saturation
parameter real ACLM     = 220 	    from [0.0:inf];
parameter real DELTA     = 2.0	    from [0.0:inf]; //  order of VSAT model between 1-2
parameter real    CIT            = 0e-8  from [0.0:inf];      //"C/m^2"   Interface Trap density
parameter real    NFACTOR            = 0.0  from [0.0:inf];      //                       Sub-threshold slope factor
parameter real    CDSCD           =1e-9       from [0.0:inf];      //"F/m^2/V"        "d-bias sensitivity of sub-threshold slope" )
parameter real    CDSCB           =0       from [0.0:inf];      //"F/m^2/V"        "Body-bias sensitivity of sub-threshold slope" )
//parameter real    Cb 	     = 0.0026	    from (0.0:inf); // AlGaN CAPACITANCE PER UNIT AREA
parameter real    U0 	     = 0.165	    from (0.0:inf); // Low field mobility
parameter real    UA 	     = 3.0	    from [0.0:inf]; // Mobility reduction factor
parameter real    UC 	     = 0.0	    from [0.0:inf]; // Mobility reduction with body bias
parameter real    UD 	     = 37.0	    from [0.0:inf]; // Coulomb scattering parameter
parameter real    EU 	     = 1.0	    from [0.0:inf]; // Mobility reduction exponent
parameter real    BEX 	     = -2.0; 	    	 	    // Mobility temperature exponent  
parameter real    UCEX 	     = 0.025; 	    	 	    // Longitudinal critical field temperature exponent
parameter real    ETAVSAT 	     = 0.5; 	    	 	    // Longitudinal critical field temperature coeff
parameter real    USC 	     = 1	    from [0.0:inf]; // Coulomb scattering parameter
parameter real    AVDSX 	     = 40	    from [5.0:100]; // Smoothing parameter in Vdsx in Vbsx
parameter real    LC 	     = 10e-9	    from (0:inf]; // LC
parameter real    LAMBDA     = 0.00	    from [0.0:inf]; // Depletion length coefficient (channel length modulation)
parameter real    PTWG     = 0.0	    from [0.0:inf]; // VG coefficient (channel length modulation)
parameter integer    TYPE=`type_n      from [-1:1];  // type_n=1  type_p=-1
parameter integer type            = 1             from[-1:1] exclude 0; //               nFET=1 pFET=-1
parameter real    rth             =30         from [0:inf);         // K/W           Thermal resistance
parameter real    cth             = 1e-9          from [0:inf);         // s.W/K         Thermal capacitance
parameter real    ns0    	     = 5.0e17*25	    from [0.0:inf];
parameter real    mu0acc    	     = 0.165	    from [0.0:inf];
parameter real    vsat0acc    	     =5.0e4	    from [0.0:inf];
parameter real    Rcs    	     = 1.0e-4	    from [0.0:inf];
parameter         ktrs               = 0.00          from [0.0:inf];
parameter         ktrd               =0.00          from [0.0:inf];
parameter real    Rcd    	     = 1.0e-4	    from [0.0:inf];
parameter real kth1    	     = 0.00  from [0.0:inf];
parameter real kth2    	     = 0.00	    from [0.0:inf];
parameter real kth3    	     = 0.0	    from [-inf:inf];
parameter real gsar    	     = 2.2	    from [-inf:inf];
parameter integer flagfp1         = 1             from[0:1];            //               Flag parameter: GFP=1 or SFP=0
parameter real    lgfp1           = 2e-6         from[0.0:inf];        // um            FP Length
parameter real    vtofp1          = -35.3         from[-inf:inf];       // V             FP Threshold Voltage
parameter real    cbfp1           = 0      from[0:inf];          // F/m           Body to d (under FP) Cap/Width
parameter real    minl            = 1.0e-9        from[0.0:inf];        // um            Minimum length
parameter real    minc            = 1.0e-15       from[0.0:inf];        // F             Minimum capacitance 
parameter real    minr            = 1.0e-3        from[0.0:inf];        // Ohms          Minimum resistance
parameter real    rgsp            = 0.0           from[0.0:inf];        // Ohms*m        Gate resistance * Width
//
//***********************************************
//
// Clamped exponential function
//
//***********************************************
//
analog function real lexp;
    input x;
    real x;
    begin
        if (x > `EXPL_THRESHOLD) begin
            lexp = `MAX_EXPL * (1.0 + x - `EXPL_THRESHOLD);
        end else if (x < -`EXPL_THRESHOLD) begin
            lexp = `MIN_EXPL;
        end else begin
            lexp = exp(x);
        end
    end
endfunction
//
//***********************************************
//
// Clamped log function
//
//***********************************************
//
analog function real lln;
    input x;
    real x;
    begin
        lln = ln(max(x, `N_MINLOG));
    end
endfunction
//
//***********************************************
//
// Hyperbolic smoothing function
//
//***********************************************
//
analog function real hypsmooth;
    input x, c;
    real x, c;
    begin
        hypsmooth = 0.5 * (x + sqrt(x * x + 4.0 * c * c));
    end
endfunction
//
//***********************************************
//	
 //sd_dir function
 //
//***********************************************
//
analog function real sd_dir;
    inout vgsout,vdsout;
    input type,vgsin,vgdin,vdsin;
    real  type,vgsout,vdsout,vgsin,vgdin,vdsin;
    real  vgsType,vgdType,vdsType;
    begin
       vgsType      = vgsin * type;
       vgdType      = vgdin * type;
       vdsType      = vdsin * type;
       vgsout       = vgsType;
       vdsout       = vdsType;
	  sd_dir       = 1.0;
    end 
 endfunction // sd_dir
 //
//***********************************************
// 
//core function
 analog function real core;
      input vch,pinch_n,n_q,gam,cb,DOS_2D,gg,UT,v_s,phib;
      real vrbl,vch,pinch_n,gam,cb,DOS_2D,gg,UT,phib;
      real v_s,a,n0,alpha,d,beta,n_q,Qsp;
 	 real T0,T1,T2,T3,T4;
 	 begin     
      vrbl=pinch_n-v_s+phib-vch;  
      Qsp=2*n_q*cb*UT;	 
      a=q/(cb*n_q); 
      n0=DOS_2D*UT; 
      alpha=a*n0/UT;  
      if (vrbl <= 0.0) begin 
 	     T0 = 6 / exp(vrbl); 
          T1 =(T0+alpha+2/3*beta*(T0)**(1/3))/(1+vrbl+ln(T0)-1/3*beta*(T0)**(-2/3)); 
          T2 =(T1+alpha+2/3*beta*(T1)**(1/3))/(1+vrbl+ln(T1)-1/3*beta*(T1)**(-2/3)); 
          T4 =(1+vrbl+ln(T2)-1/3*beta*(T2)**(-2/3))/(T2+alpha+2/3*beta*(T2)**(1/3)); 
 		 core =q*n0*T4/Qsp; 
      end else begin 
 	 if (vrbl<50) begin 
             T0=1/((vrbl/(alpha+beta))+0.5); 
             T1=(T0+alpha+2/3*beta*(T0)**(1/3))/(1+vrbl+ln(T0)-1/3*beta*(T0)**(-2/3)); 
             T2=(T1+alpha+2/3*beta*(T1)**(1/3))/(1+vrbl+ln(T1)-1/3*beta*(T1)**(-2/3)); 
             T4=(1.0+vrbl+ln(T2)-1/3*beta*(T2)**(-2/3))/(T2+alpha+2/3*beta*(T2)**(1/3)); 
 			core =q*n0*T4/Qsp; 
      end else begin 
             T0=3/((vrbl/(alpha+beta))+0.5); 
             T1=(1+alpha+2/3*beta*(T0)**(1/3))/(0.5+vrbl-1/3*beta*(T0)**(-2/3)); 
             T2=(1+alpha+2/3*beta*(T1)**(1/3))/(0.5+vrbl-1/3*beta*(T1)**(-2/3)); 
             T3=(1+alpha+2/3*beta*(T2)**(1/3))/(0.5+vrbl-1/3*beta*(T2)**(-2/3)); 
            T4=(1.0+1*vrbl-1/3*beta*(T3)**(-2/3))/(1.0+alpha+2/3*beta*(T3)**(1/3)); 
 		   core =q*n0*T4/Qsp; 
      end 
 	 end 
 	 end 
   endfunction //core           
//
//***********************************************
//
//access function
//
//***********************************************
//
analog function real access;
     input R0,Vcrit,Vch,gsar;
     real R0,Vcrit,Vch,gsar,T0,T1,T2;
   
	 begin
     T0=Vch/Vcrit;
    T1=pow(T0,gsar);
	 T2=pow(1+T1,1/gsar);
     access=Vch/(R0*T2);
     end

 endfunction //access   
 //
//***********************************************
//  
analog function real calc_Ids;
//
//***********************************************
//
//**********output idsout*********************
input Vd,Vg,Vs,VA,cb,phist,UT,phib,Leff;
real idsout,Vgs,Vdss,Vd,Vg,Vs,VA,cb,pinch_n,phist,UT,phib,Leff;
//
//***********************************************
//
// Common variables
//
//***********************************************
//
integer type;
real T0, T1, T2, T3, T4, T5, T6, T7, T8, T9,T10,T11,T12;
real sigvds,vA,vg_vA, Vbsx;
real vg,vs,Vdsx,vd,VDAR,VSAR;
real Vth_shift;
real qia, qba, qbs, phib_n;
real nq, psiavg, pinch_norm_cl, sqrtpsip;
real Cdep;
real v_s,n0,dat,beta,n_q,Qsp,Vds;	
//
//***********************************************
//
// Material Parameters 
//
//***********************************************
//
real EgGaN,EgAlN,EgAlGaN;
real ep_AlGaN, Ef_AlGaN,DOS_2D;
//
//***********************************************
//
//CLM Parameters
//
//***********************************************
//
real diffVds,core,Core,a,vrbl,alpha; 
real qsqdp,qs_qdp,powqs_qdp2,qsqdpp1;	
//
//***********************************************
// 
//drain saturation voltage
//
//***********************************************
// 
real LambdaC,qdsat,vdsat,vdssat,qdeff; 
real g_clm,e_clm,e_clmx2,e_clm2,e_clmp2,e_clmx2xqs;
real qs_qsat,qs_qsat2,mdm2,e_clmxmdm2_2,tmp_vdsat1,tmp_vdsat11,tmp_vdsat2;
real dv_clm,tmp_vdp1,tmp_vdp2,tmp_vdp3,vdp,u_clm,alpha_clm,deltal;
 //Short channel effects
real n, nUT, inv_nUT, inv_UT;
real PhistVbs, sqrtPhistVbs, Xdep, cdsc;
real T1DEP;
real dVth_dibl;
real gam, inv_gam, Phist;
//
//***********************************************
// 
// Vertical Field 
//
//***********************************************
// 
real EeffF,Eeffs,eta_mu,qis,Vmr,Eeffm,E0_t;
//
//***********************************************
// 
// charge variables
//
//***********************************************
// 
real qs,vp;
real DQSD2,Qb,Qs,Qd;
real tambk, tsh, tdut, pdiss, mut, TRatio,UCRIT_T;
//
//***********************************************
// 
// Velocity Saturation  
//
//***********************************************
// 
 real Dvsat,Dr;
 //
//***********************************************
// 
 //transconductance 
 //
//***********************************************
// 
 real  difqdeff_VG,difqs_VG,difqdeff_VD,Gm,Gds;	
 real Dtot,ueff,ids,Isp,IDS;
//
//***********************************************
// 
begin
       DOS_2D=0.2*me/((1/q)*pi*(1.05459e-34)**2);

    Vds  = Vd - Vs;
    T0   = AVDSX * Vds;
    if (T0 > `EXPL_THRESHOLD) begin
       T1 = T0;
    end else begin
       T1 = ln(1.0 + exp(T0));
    end
    Vdsx = ((2.0/AVDSX) * T1) - Vds - ((2.0/AVDSX) * ln(2.0));
    Vbsx = -(Vs + 0.5 * (Vds - Vdsx));
$strobe(">- DOS_2D = %g V \t  Vds = %g V \t T1 = %g V \t Vdsx = %g V \t Vbsx = %g V \t", DOS_2D,  Vds,T1,Vdsx,Vbsx);
//
//***********************************************
// 
   // SCE, DIBL, SS degradation effects
   //
//***********************************************
// 
    `Smooth(Phist - Vbsx, 0.05, 0.1, PhistVbs)
    sqrtPhistVbs = sqrt(PhistVbs);
    Xdep         = T1DEP * sqrtPhistVbs;
    Cdep         = ep_GaN / Xdep;
    cdsc         = CIT + NFACTOR + CDSCD * Vdsx - CDSCB* Vbsx;
    T1           = 1.0 + cdsc/cb;
    `Smooth(T1, 1, 0.05, n)
    nUT     = n * UT;
    inv_nUT = 1.0 / nUT;
    vd    = Vd * inv_nUT;
    vg    = Vg * inv_nUT;
    vs    = Vs * inv_nUT;
    vA   = VA * inv_nUT;
//
//***********************************************
// 
// Vth Shift for 
//
//***********************************************
// 
  dVth_dibl = -(ETA0 + ETAB * Vbsx) * Vdsx;
Vth_shift = dVth_dibl;
	
vg_vA      = vg - vA - Vth_shift * inv_nUT;
gam     = sqrt(2.0 * q * ep_GaN* NDEP * inv_UT) / cb;
inv_gam=1/gam;
phib_n = phib / n;
//
//***********************************************
// 
`pinch_norm(vg_vA, gam, pinch_n)
`Smooth(pinch_n, 1.0, 2.0, pinch_norm_cl)
   sqrtpsip = sqrt(pinch_norm_cl);
   n_q=1+gam/(2*sqrt(pinch_norm_cl));
     Qsp=2*n_q*cb*UT;
dat=gg/UT; 
beta=dat*n0**(0.6666); 
v_s=ln(NDEP/NV)+EgGaN/(q*UT);
//end function
qs=core(vs,pinch_n,n_q,gam,cb,DOS_2D,gg,UT,v_s,phib);
// source side surf pot.
psiavg = pinch_n - 2.0 * qs;
`Smooth(psiavg, 1.0, 2.0, T0);
nq = 1.0 + gam / (sqrtpsip + sqrt(T0));
	
//
//***********************************************
// 
 EeffF =cb /(E0_t*ep_GaN);
 T0 = nUT * (vg_vA - pinch_n - 2.0 * qs * (nq - 1.0));
 `Smooth(T0, 0, 0.1, qbs)	
//
//***********************************************
// 
// Source side qi and qb for Vdsat
//
//***********************************************
// 
 qis = 2.0 * nq * nUT * qs;
 Eeffs = EeffF * (qbs + eta_mu * qis);
//
//***********************************************
// 
//  mobility model
//
//***********************************************
// 
 T2 = pow(0.5 * (1.0 + (qis / qbs)), USC);
 T3 = (UA + UC * Vbsx) * pow(Eeffs, EU) + UD / T2;
 T4 = 1.0 + T3;
 `Smooth(T4, 1.0, 0.0015, Vmr)
UCRIT_T  = UCRIT * pow(TRatio, -UCEX);
//
//***********************************************
// 
// Saturation Voltage
//
//***********************************************
// 
    vp 		= pinch_n  - phib;
	//
//***********************************************
// 
// -- VELOCITY SATURATION (NOT DEPENDENT ON VD) for intrinsic gate transistor
//
//***********************************************
// 
	g_clm 		= 0.1; // NOTE: Also used for the calculation of mobility reduction due to CHANNEL LENGTH MODULATION
	e_clm 		= 2.0*nUT / (UCRIT_T*L); // NOTE: Also used for the calculation of mobility reduction due to CHANNEL LENGTH MODULATION
	e_clm2 		= e_clm * e_clm; // NOTE: Also used for the calculation of mobility reduction due to CHANNEL LENGTH MODULATION
	e_clmx2 	= 2.0 * e_clm;
	e_clmp2 	= 2.0 + e_clm;
	e_clmx2xqs 	= e_clmx2 * qs;
	qdsat 		= e_clmx2 * (qs**2 + qs) / (e_clmp2 + e_clmx2xqs + sqrt(e_clmp2 * e_clmp2 + 4.0 * e_clmx2xqs)); // NOTE: The inversion charge at a point of maximum velocity saturation.
	qs_qsat 	= qs - qdsat;
	qs_qsat2 	= qs_qsat * qs_qsat;
	mdm2 		= 2.0 - DELTA; // NOTE: Also used for the calculation of mobility reduction due to CHANNEL LENGTH MODULATION
	e_clmxmdm2_2 	= e_clm2 * mdm2 * mdm2; // NOTE: Also used for the calculation of mobility reduction due to CHANNEL LENGTH MODULATION
	tmp_vdsat1 	= (2.0 * qdsat + ln(qdsat)) * (1.0 + e_clm * qs_qsat);
 	tmp_vdsat11	= g_clm + e_clm * mdm2 * qs_qsat;
 	tmp_vdsat2 	= sqrt(1.0 + (2.0 * e_clm2 * mdm2 * mdm2 * qs_qsat2) / tmp_vdsat11 + e_clm2 * qs_qsat2);
 	vdsat 		= vp - tmp_vdsat1 / tmp_vdsat2; // NOTE: The potential at a point of the channel of maximum velocity saturation.
	`Smooth(vdsat - vs, 3.0, 4, vdssat)	
	//
	//
//***********************************************
// 
//  VELOCITY SATURATION (DEPENDENT ON VD)
//
//***********************************************
// 
 	dv_clm 		= (ACLM / DELTA) * (4.0 * qdsat + DELTA) / (qs + 1.0);
	tmp_vdp1 	= (vd - vs) * sqrt(1.0 + 4.0 * dv_clm / vdssat);
	tmp_vdp2 	= sqrt((tmp_vdp1 + vdssat) * (tmp_vdp1 + vdssat) + 4.0 * dv_clm * vdssat);
	tmp_vdp3 	= sqrt((tmp_vdp1 - vdssat) * (tmp_vdp1 - vdssat) + 4.0 * dv_clm * vdssat);
	vdp 		= 0.5 * (tmp_vdp2 - tmp_vdp3) + vs; // NOTE: The potential at the velocity saturated point of the channel, limited by the maximum value (vdsat)
	//
//***********************************************
// 
// -- CHANNEL LENGTH MODULATION 
//
//***********************************************
// 
	u_clm		= 0.5 * e_clm * Leff / LC * (vd - vdp);
	alpha_clm 	= LC / (Leff - 2.0 * LC);
	deltal 		= LAMBDA * LC * ln((alpha_clm + u_clm + sqrt(u_clm * u_clm + 2.0 * alpha_clm * u_clm + 1.0)) / (alpha_clm + 1.0)); // NOTE: The distance between the velocity saturated point of the channel and the (electrical) drain end. Used at the SPECIFIC CURRENT calculation.
//
//***********************************************
// 
// CALCULATION OF NORMALIZED INVERSION CHARGE OF THE VELOCITY SATURATED POINT (ELECTRICAL DRAIN END)
//
//***********************************************
// 
qdeff=core(vdp,pinch_n,nq,gam,cb,DOS_2D,gg,UT,v_s,phib);// Reevaluation of nq to include qdeff
psiavg = pinch_n -qs-qdeff;
`Smooth(psiavg, 1.0, 2.0, T0)
T2 = sqrt(T0);
nq = 1.0 + gam / (sqrtpsip + T2);
//
//***********************************************
// 
    // Inversion and bulk charge
	//
//***********************************************
// 
    DQSD2 = (qs - qdeff) * (qs - qdeff);
    T0    = 1.0 / (1.0 + qs + qdeff);
    T1    = DQSD2 * T0;
    Qb    = vg_vA - pinch_n - (nq - 1.0) * (qs + qdeff + `Oneby3 * T1);
    T2    = `Oneby3 * nq;
    T3    = T1 * T0;
    Qs    = T2 * (2.0 * qs + qdeff + 0.5 * (1.0 + 0.8 * qs + 1.2 * qdeff) * T3);
    Qd    = T2 * (qs + 2.0 * qdeff + 0.5 * (1.0 + 1.2 * qs + 0.8 * qdeff) * T3);
 //
//***********************************************
// 
    // Mobility degradation
    // Average charges (qba and qia) - normalized to Cb
	//
//***********************************************
// 
    `Smooth(nUT * Qb, 0, 0.1, qba)
    qia   = nUT * (Qs + Qd);
    Eeffm = EeffF * (qba + eta_mu * qia);
    T2    = pow(0.5 * (1.0 + (qia / qba)), USC);
    T3    = (UA + UC * Vbsx) * pow(Eeffm, EU) + UD / T2;
    T4    = 1.0 + T3;
    `Smooth(T4, 1.0, 0.0015, Vmr)
//
//***********************************************
// 
	qsqdp 		= qs + qdeff;
	qs_qdp 		= qs - qdeff;
	powqs_qdp2 	= qs_qdp * qs_qdp;
	qsqdpp1 	= qsqdp + 1.0;
	Dvsat 	= sqrt(1.0 + 4.0 * e_clmxmdm2_2 * powqs_qdp2 / (g_clm + e_clm * mdm2 * (qs_qdp)) + e_clm2 * powqs_qdp2);
//
//***********************************************
// 
   Dr=1;
   Dtot = Vmr * Dvsat * Dr;

    // Effective mobility including mobility degradation
 ueff = mut / Dtot;
 
  Isp=2.0 * NF * nq * ueff * W / (Leff-deltal) * cb * nUT * nUT ;
//
//***********************************************
//  
 idsout  = Isp * ((qs - qdeff) * (1.0 + qs + qdeff));
  T1=q/(nq*Qsp);
T2=1/DOS_2D;  
T3=-(Qsp*qs/q)/(DOS_2D*UT);
T4=T2/(1-exp(T3));
T5=q/(cb*nq);   
T6=2*gg/(3*((Qsp*qs/q)**(1/3)));
difqs_VG=T1/(T4+T5+T6);
T1=q/(nq*Qsp);
T2=1/DOS_2D;  
T3=-(Qsp*qdeff/q)/(DOS_2D*UT);
T4=T2/(1-exp(T3));
T5=q/(cb*nq);   
T6=2*gg/(3*((Qsp*qdeff/q)**(1/3)));
difqdeff_VG=T1/(T4+T5+T6);
T1=q/(nq*Qsp);
T2=1/DOS_2D;  
T3=-(Qsp*qdeff/q)/(DOS_2D*UT);
T4=T2/(1-exp(T3));
T5=q/(cb*nq);   
T6=2*gg/(3*((Qsp*qdeff/q)**(1/3)));
difqdeff_VD=T1/(T4+T5+T6);
Gm=Isp * (difqs_VG*(1+2*qs)-difqdeff_VG*(1+2*qdeff));
Gds=-Isp *difqdeff_VD*(1+2*qdeff);
lc_Ids=idsout;
   end  	
  endfunction
  
 //**********output idsout (FP1)*********************
input Vd_fp1, Vg_fp1, Vs_fp1, VA_fp1, cb_fp1, phist_fp1, UT_fp1, phib_fp1, Leff_fp1;
real idsout_fp1, Vgs_fp1, Vdss_fp1, Vd_fp1, Vg_fp1, Vs_fp1, VA_fp1, cb_fp1, 
     pinch_n_fp1, phist_fp1, UT_fp1, phib_fp1, Leff_fp1;

//***********************************************
//
// Common variables (FP1)
//
//***********************************************
//
integer type_fp1;
real T0_fp1, T1_fp1, T2_fp1, T3_fp1, T4_fp1, T5_fp1, T6_fp1, T7_fp1, T8_fp1, T9_fp1, T10_fp1, T11_fp1, T12_fp1;
real sigvds_fp1, vA_fp1, vg_vA_fp1, Vbsx_fp1;
real vg_fp1, vs_fp1, Vdsx_fp1, vd_fp1, VDAR_fp1, VSAR_fp1;
real Vth_shift_fp1;
real qia_fp1, qba_fp1, qbs_fp1, phib_n_fp1;
real nq_fp1, psiavg_fp1, pinch_norm_cl_fp1, sqrtpsip_fp1;
real Cdep_fp1;
real v_s_fp1, n0_fp1, dat_fp1, beta_fp1, n_q_fp1, Qsp_fp1, Vds_fp1;

//***********************************************
//
// Material Parameters (FP1)
//
//***********************************************
//
real EgGaN_fp1, EgAlN_fp1, EgAlGaN_fp1;
real ep_AlGaN_fp1, Ef_AlGaN_fp1, DOS_2D_fp1;

//***********************************************
//
// CLM Parameters (FP1)
//
//***********************************************
//
real diffVds_fp1, core_fp1, Core_fp1, a_fp1, vrbl_fp1, alpha_fp1;
real qsqdp_fp1, qs_qdp_fp1, powqs_qdp2_fp1, qsqdpp1_fp1;

//***********************************************
//
// drain saturation voltage (FP1)
//
//***********************************************
//
real LambdaC_fp1, qdsat_fp1, vdsat_fp1, vdssat_fp1, qdeff_fp1;
real g_clm_fp1, e_clm_fp1, e_clmx2_fp1, e_clm2_fp1, e_clmp2_fp1, e_clmx2xqs_fp1;
real qs_qsat_fp1, qs_qsat2_fp1, mdm2_fp1, e_clmxmdm2_2_fp1, tmp_vdsat1_fp1, tmp_vdsat11_fp1, tmp_vdsat2_fp1;
real dv_clm_fp1, tmp_vdp1_fp1, tmp_vdp2_fp1, tmp_vdp3_fp1, vdp_fp1, u_clm_fp1, alpha_clm_fp1, deltal_fp1;

// Short channel effects (FP1)
real n_fp1, nUT_fp1, inv_nUT_fp1, inv_UT_fp1;
real PhistVbs_fp1, sqrtPhistVbs_fp1, Xdep_fp1, cdsc_fp1;
real T1DEP_fp1;
real dVth_dibl_fp1;
real gam_fp1, inv_gam_fp1, Phist_fp1;

//***********************************************
//
// Vertical Field (FP1)
//
//***********************************************
//
real EeffF_fp1, Eeffs_fp1, eta_mu_fp1, qis_fp1, Vmr_fp1, Eeffm_fp1, E0_t_fp1;

//***********************************************
//
// charge variables (FP1)
//
//***********************************************
//
real qs_fp1, vp_fp1;
real DQSD2_fp1, Qb_fp1, Qs_fp1, Qd_fp1;
real tambk_fp1, tsh_fp1, tdut_fp1, pdiss_fp1, mut_fp1, TRatio_fp1, UCRIT_T_fp1;

//***********************************************
//
// Velocity Saturation (FP1)
//
//***********************************************
//
real Dvsat_fp1, Dr_fp1;

//***********************************************
//
// transconductance (FP1)
//
//***********************************************
//
real difqdeff_VG_fp1, difqs_VG_fp1, difqdeff_VD_fp1, Gm_fp1, Gds_fp1;
real Dtot_fp1, ueff_fp1, ids_fp1, Isp_fp1, IDS_fp1; 
 //
//***********************************************
//  FP1 REGION CALCULATIONS 
//
//***********************************************
// 

    Vds_fp1 = Vd_fp1 - Vs_fp1;
    T0_fp1 = AVDSX_fp1 * Vds_fp1;
    if (T0_fp1 > `EXPL_THRESHOLD) begin
       T1_fp1 = T0_fp1;
    end else begin
       T1_fp1 = ln(1.0 + exp(T0_fp1));
    end
    Vdsx_fp1 = ((2.0/AVDSX_fp1) * T1_fp1) - Vds_fp1 - ((2.0/AVDSX_fp1) * ln(2.0));
    Vbsx_fp1 = -(Vs_fp1 + 0.5 * (Vds_fp1 - Vdsx_fp1));

$strobe(">- DOS_2D_fp1 = %g V \t Vds_fp1 = %g V \t T1_fp1 = %g V \t Vdsx_fp1 = %g V \t Vbsx_fp1 = %g V \t",
        DOS_2D_fp1, Vds_fp1, T1_fp1, Vdsx_fp1, Vbsx_fp1);
//
//***********************************************
// 
// SCE, DIBL, SS degradation effects for FP1
//
//***********************************************
// 
    `Smooth(Phist_fp1 - Vbsx_fp1, 0.05, 0.1, PhistVbs_fp1)
    sqrtPhistVbs_fp1 = sqrt(PhistVbs_fp1);
    Xdep_fp1 = T1DEP_fp1 * sqrtPhistVbs_fp1;
    Cdep_fp1 = ep_GaN_fp1 / Xdep_fp1;

    cdsc_fp1 = CIT_fp1 + NFACTOR_fp1 + CDSCD_fp1 * Vdsx_fp1 - CDSCB_fp1 * Vbsx_fp1;
    T1_fp1 = 1.0 + cdsc_fp1 / cb_fp1;
    `Smooth(T1_fp1, 1, 0.05, n_fp1)

    nUT_fp1 = n_fp1 * UT_fp1;
    inv_nUT_fp1 = 1.0 / nUT_fp1;

    vd_fp1 = Vd_fp1 * inv_nUT_fp1;
    vg_fp1 = Vg_fp1 * inv_nUT_fp1;
    vs_fp1 = Vs_fp1 * inv_nUT_fp1;
    vA_fp1 = VA_fp1 * inv_nUT_fp1;
//
//***********************************************
// 
// Vth Shift for DIBL (FP1)
//
//***********************************************
// 
    dVth_dibl_fp1 = -(ETA0_fp1 + ETAB_fp1 * Vbsx_fp1) * Vdsx_fp1;
    Vth_shift_fp1 = dVth_dibl_fp1;
    vg_vA_fp1 = vg_fp1 - vA_fp1 - Vth_shift_fp1 * inv_nUT_fp1;

    gam_fp1 = sqrt(2.0 * q_fp1 * ep_GaN_fp1 * NDEP_fp1 * inv_UT_fp1) / cb_fp1;
    inv_gam_fp1 = 1 / gam_fp1;
    phib_n_fp1 = phib_fp1 / n_fp1;

`pinch_norm(vg_vA_fp1, gam_fp1, pinch_n_fp1)
`Smooth(pinch_n_fp1, 1.0, 2.0, pinch_norm_cl_fp1)

   sqrtpsip_fp1 = sqrt(pinch_norm_cl_fp1);
   n_q_fp1 = 1 + gam_fp1 / (2 * sqrt(pinch_norm_cl_fp1));
   Qsp_fp1 = 2 * n_q_fp1 * cb_fp1 * UT_fp1;

   dat_fp1 = gg_fp1 / UT_fp1;
   beta_fp1 = dat_fp1 * n0_fp1 ** (0.6666);
   v_s_fp1 = ln(NDEP_fp1 / NV_fp1) + EgGaN_fp1 / (q_fp1 * UT_fp1);

   qs_fp1 = core(vs_fp1, pinch_n_fp1, n_q_fp1, gam_fp1, cb_fp1, DOS_2D_fp1, gg_fp1, UT_fp1, v_s_fp1, phib_fp1);
//
//***********************************************
// 
// source side surface potential
//
//***********************************************
//   
   psiavg_fp1 = pinch_n_fp1 - 2.0 * qs_fp1;
   `Smooth(psiavg_fp1, 1.0, 2.0, T0_fp1);
   nq_fp1 = 1.0 + gam_fp1 / (sqrtpsip_fp1 + sqrt(T0_fp1));

   EeffF_fp1 = cb_fp1 / (E0_t_fp1 * ep_GaN_fp1);
   T0_fp1 = nUT_fp1 * (vg_vA_fp1 - pinch_n_fp1 - 2.0 * qs_fp1 * (nq_fp1 - 1.0));
   `Smooth(T0_fp1, 0, 0.1, qbs_fp1);
//
//***********************************************
// 
// Source side qi and qb for Vdsat (FP1)
//
//***********************************************
//   
   qis_fp1 = 2.0 * nq_fp1 * nUT_fp1 * qs_fp1;
   Eeffs_fp1 = EeffF_fp1 * (qbs_fp1 + eta_mu_fp1 * qis_fp1);
//
//***********************************************
// 
// Mobility model (FP1)
//
//***********************************************
// 
   T2_fp1 = pow(0.5 * (1.0 + (qis_fp1 / qbs_fp1)), USC_fp1);
   T3_fp1 = (UA_fp1 + UC_fp1 * Vbsx_fp1) * pow(Eeffs_fp1, EU_fp1) + UD_fp1 / T2_fp1;
   T4_fp1 = 1.0 + T3_fp1;
   `Smooth(T4_fp1, 1.0, 0.0015, Vmr_fp1);

   UCRIT_T_fp1 = UCRIT_fp1 * pow(TRatio_fp1, -UCEX_fp1);
//
//***********************************************
// 
// Saturation Voltage (FP1)
//
//***********************************************
// 
   vp_fp1 = pinch_n_fp1 - phib_fp1;

//
//***********************************************
//  FP1 VELOCITY SATURATION & CHANNEL LENGTH MODULATION 
//
//***********************************************
// 
    g_clm_fp1 = 0.1;
    e_clm_fp1 = 2.0 * nUT_fp1 / (UCRIT_T_fp1 * L_fp1);

    e_clm2_fp1 = e_clm_fp1 * e_clm_fp1;
    e_clmx2_fp1 = 2.0 * e_clm_fp1;
    e_clmp2_fp1 = 2.0 + e_clm_fp1;
    e_clmx2xqs_fp1 = e_clmx2_fp1 * qs_fp1;

    qdsat_fp1 = e_clmx2_fp1 * (qs_fp1**2 + qs_fp1) / 
                (e_clmp2_fp1 + e_clmx2xqs_fp1 + sqrt(e_clmp2_fp1 * e_clmp2_fp1 + 4.0 * e_clmx2xqs_fp1));

    qs_qsat_fp1 = qs_fp1 - qdsat_fp1;
    qs_qsat2_fp1 = qs_qsat_fp1 * qs_qsat_fp1;

    mdm2_fp1 = 2.0 - DELTA_fp1;

    e_clmxmdm2_2_fp1 = e_clm2_fp1 * mdm2_fp1 * mdm2_fp1;

    tmp_vdsat1_fp1 = (2.0 * qdsat_fp1 + ln(qdsat_fp1)) * (1.0 + e_clm_fp1 * qs_qsat_fp1);
    tmp_vdsat11_fp1 = g_clm_fp1 + e_clm_fp1 * mdm2_fp1 * qs_qsat_fp1;
    tmp_vdsat2_fp1 = sqrt(1.0 + (2.0 * e_clm2_fp1 * mdm2_fp1 * mdm2_fp1 * qs_qsat2_fp1) / tmp_vdsat11_fp1 
                            + e_clm2_fp1 * qs_qsat2_fp1);

    vdsat_fp1 = vp_fp1 - tmp_vdsat1_fp1 / tmp_vdsat2_fp1;
	
//
//***********************************************
// 
// VELOCITY SATURATION (DEPENDENT ON VD) for FP1
//
//***********************************************
// 
  dv_clm_fp1 = (ACLM_fp1 / DELTA_fp1) * (4.0 * qdsat_fp1 + DELTA_fp1) / (qs_fp1 + 1.0);

  tmp_vdp1_fp1 = (vd_fp1 - vs_fp1) * sqrt(1.0 + 4.0 * dv_clm_fp1 / vdssat_fp1);
  tmp_vdp2_fp1 = sqrt((tmp_vdp1_fp1 + vdssat_fp1) * (tmp_vdp1_fp1 + vdssat_fp1) + 4.0 * dv_clm_fp1 * vdssat_fp1);
  tmp_vdp3_fp1 = sqrt((tmp_vdp1_fp1 - vdssat_fp1) * (tmp_vdp1_fp1 - vdssat_fp1) + 4.0 * dv_clm_fp1 * vdssat_fp1);

  vdp_fp1 = 0.5 * (tmp_vdp2_fp1 - tmp_vdp3_fp1) + vs_fp1; 
  // NOTE: The potential at the velocity saturated point of the channel (FP1)

//
//***********************************************
// 
// -- CHANNEL LENGTH MODULATION - FP1
//
//***********************************************
// 
  u_clm_fp1 = 0.5 * e_clm_fp1 * Leff_fp1 / LC_fp1 * (vd_fp1 - vdp_fp1);
  alpha_clm_fp1 = LC_fp1 / (Leff_fp1 - 2.0 * LC_fp1);

  deltal_fp1 = LAMBDA_fp1 * LC_fp1 * ln((alpha_clm_fp1 + u_clm_fp1 + 
               sqrt(u_clm_fp1 * u_clm_fp1 + 2.0 * alpha_clm_fp1 * u_clm_fp1 + 1.0)) / 
               (alpha_clm_fp1 + 1.0));

//
//***********************************************
// 
// CALCULATION OF NORMALIZED INVERSION CHARGE AT VELOCITY SATURATED POINT (FP1)
//
//***********************************************
// 
  qdeff_fp1 = core(vdp_fp1, pinch_n_fp1, nq_fp1, gam_fp1, cb_fp1, DOS_2D_fp1, gg_fp1, UT_fp1, v_s_fp1, phib_fp1);

  psiavg_fp1 = pinch_n_fp1 - qs_fp1 - qdeff_fp1;
  `Smooth(psiavg_fp1, 1.0, 2.0, T0_fp1);
  T2_fp1 = sqrt(T0_fp1);
  nq_fp1 = 1.0 + gam_fp1 / (sqrtpsip_fp1 + T2_fp1);

//
//***********************************************
// 
// Inversion and bulk charge (FP1)
//
//***********************************************
// 
  DQSD2_fp1 = (qs_fp1 - qdeff_fp1) * (qs_fp1 - qdeff_fp1);
  T0_fp1 = 1.0 / (1.0 + qs_fp1 + qdeff_fp1);
  T1_fp1 = DQSD2_fp1 * T0_fp1;

  Qb_fp1 = vg_vA_fp1 - pinch_n_fp1 - (nq_fp1 - 1.0) * (qs_fp1 + qdeff_fp1 + `Oneby3 * T1_fp1);

  T2_fp1 = `Oneby3 * nq_fp1;
  T3_fp1 = T1_fp1 * T0_fp1;

  Qs_fp1 = T2_fp1 * (2.0 * qs_fp1 + qdeff_fp1 + 0.5 * (1.0 + 0.8 * qs_fp1 + 1.2 * qdeff_fp1) * T3_fp1);
  Qd_fp1 = T2_fp1 * (qs_fp1 + 2.0 * qdeff_fp1 + 0.5 * (1.0 + 1.2 * qs_fp1 + 0.8 * qdeff_fp1) * T3_fp1);

//
//***********************************************
// 
// Mobility degradation - Average charges (FP1)
//
//***********************************************
// 
  `Smooth(nUT_fp1 * Qb_fp1, 0, 0.1, qba_fp1);
  qia_fp1 = nUT_fp1 * (Qs_fp1 + Qd_fp1);

  Eeffm_fp1 = EeffF_fp1 * (qba_fp1 + eta_mu_fp1 * qia_fp1);

  T2_fp1 = pow(0.5 * (1.0 + (qia_fp1 / qba_fp1)), USC_fp1);
  T3_fp1 = (UA_fp1 + UC_fp1 * Vbsx_fp1) * pow(Eeffm_fp1, EU_fp1) + UD_fp1 / T2_fp1;
  T4_fp1 = 1.0 + T3_fp1;
  `Smooth(T4_fp1, 1.0, 0.0015, Vmr_fp1);

//
//***********************************************
// 
// Final Dvsat & Effective mobility (FP1)
//
//***********************************************
// 
  qsqdp_fp1 = qs_fp1 + qdeff_fp1;
  qs_qdp_fp1 = qs_fp1 - qdeff_fp1;
  powqs_qdp2_fp1 = qs_qdp_fp1 * qs_qdp_fp1;
  qsqdpp1_fp1 = qsqdp_fp1 + 1.0;

  Dvsat_fp1 = sqrt(1.0 + 4.0 * e_clmxmdm2_2_fp1 * powqs_qdp2_fp1 / 
              (g_clm_fp1 + e_clm_fp1 * mdm2_fp1 * (qs_qdp_fp1)) + e_clm2_fp1 * powqs_qdp2_fp1);

  Dr_fp1 = 1.0;
  Dtot_fp1 = Vmr_fp1 * Dvsat_fp1 * Dr_fp1;
//
//***********************************************
// 
// Effective mobility
//
//***********************************************
// 
  ueff_fp1 = mut_fp1 / Dtot_fp1;

  Isp_fp1 = 2.0 * NF_fp1 * nq_fp1 * ueff_fp1 * W_fp1 / (Leff_fp1 - deltal_fp1) * 
            cb_fp1 * nUT_fp1 * nUT_fp1;

//
//***********************************************
// 
// Final Current & Derivatives (FP1)
//
//***********************************************
// 
  idsout_fp1 = Isp_fp1 * ((qs_fp1 - qdeff_fp1) * (1.0 + qs_fp1 + qdeff_fp1));

  // (Optional derivatives - commented style from original)
  // T1_fp1 = q_fp1 / (nq_fp1 * Qsp_fp1); ...
  // Gm_fp1, Gds_fp1, etc.

  calc_Ids_fp1 = idsout_fp1;   // or lc_Ids_fp1 depending on your naming
//**********output idsout (FP2)*********************
input Vd_fp2, Vg_fp2, Vs_fp2, VA_fp2, cb_fp2, phist_fp2, UT_fp2, phib_fp2, Leff_fp2;
real idsout_fp2, Vgs_fp2, Vdss_fp2, Vd_fp2, Vg_fp2, Vs_fp2, VA_fp2, cb_fp2,
     pinch_n_fp2, phist_fp2, UT_fp2, phib_fp2, Leff_fp2;

//***********************************************
//
// Common variables (FP2)
//
//***********************************************
//
integer type_fp2;
real T0_fp2, T1_fp2, T2_fp2, T3_fp2, T4_fp2, T5_fp2, T6_fp2, T7_fp2, T8_fp2, T9_fp2, T10_fp2, T11_fp2, T12_fp2;
real sigvds_fp2, vA_fp2, vg_vA_fp2, Vbsx_fp2;
real vg_fp2, vs_fp2, Vdsx_fp2, vd_fp2, VDAR_fp2, VSAR_fp2;
real Vth_shift_fp2;
real qia_fp2, qba_fp2, qbs_fp2, phib_n_fp2;
real nq_fp2, psiavg_fp2, pinch_norm_cl_fp2, sqrtpsip_fp2;
real Cdep_fp2;
real v_s_fp2, n0_fp2, dat_fp2, beta_fp2, n_q_fp2, Qsp_fp2, Vds_fp2;

//***********************************************
//
// Material Parameters (FP2)
//
//***********************************************
//
real EgGaN_fp2, EgAlN_fp2, EgAlGaN_fp2;
real ep_AlGaN_fp2, Ef_AlGaN_fp2, DOS_2D_fp2;

//***********************************************
//
// CLM Parameters (FP2)
//
//***********************************************
//
real diffVds_fp2, core_fp2, Core_fp2, a_fp2, vrbl_fp2, alpha_fp2;
real qsqdp_fp2, qs_qdp_fp2, powqs_qdp2_fp2, qsqdpp1_fp2;

//***********************************************
//
// drain saturation voltage (FP2)
//
//***********************************************
//
real LambdaC_fp2, qdsat_fp2, vdsat_fp2, vdssat_fp2, qdeff_fp2;
real g_clm_fp2, e_clm_fp2, e_clmx2_fp2, e_clm2_fp2, e_clmp2_fp2, e_clmx2xqs_fp2;
real qs_qsat_fp2, qs_qsat2_fp2, mdm2_fp2, e_clmxmdm2_2_fp2, tmp_vdsat1_fp2, tmp_vdsat11_fp2, tmp_vdsat2_fp2;
real dv_clm_fp2, tmp_vdp1_fp2, tmp_vdp2_fp2, tmp_vdp3_fp2, vdp_fp2, u_clm_fp2, alpha_clm_fp2, deltal_fp2;

// Short channel effects (FP2)
real n_fp2, nUT_fp2, inv_nUT_fp2, inv_UT_fp2;
real PhistVbs_fp2, sqrtPhistVbs_fp2, Xdep_fp2, cdsc_fp2;
real T1DEP_fp2;
real dVth_dibl_fp2;
real gam_fp2, inv_gam_fp2, Phist_fp2;

//***********************************************
//
// Vertical Field (FP2)
//
//***********************************************
//
real EeffF_fp2, Eeffs_fp2, eta_mu_fp2, qis_fp2, Vmr_fp2, Eeffm_fp2, E0_t_fp2;

//***********************************************
//
// charge variables (FP2)
//
//***********************************************
//
real qs_fp2, vp_fp2;
real DQSD2_fp2, Qb_fp2, Qs_fp2, Qd_fp2;
real tambk_fp2, tsh_fp2, tdut_fp2, pdiss_fp2, mut_fp2, TRatio_fp2, UCRIT_T_fp2;

//***********************************************
//
// Velocity Saturation (FP2)
//
//***********************************************
//
real Dvsat_fp2, Dr_fp2;

//***********************************************
//
// transconductance (FP2)
//
//***********************************************
//
real difqdeff_VG_fp2, difqs_VG_fp2, difqdeff_VD_fp2, Gm_fp2, Gds_fp2;
real Dtot_fp2, ueff_fp2, ids_fp2, Isp_fp2, IDS_fp2;  
//
//***********************************************
//  FP2 REGION CALCULATIONS 
//
//***********************************************
// 
    Vds_fp2 = Vd_fp2 - Vs_fp2;
    T0_fp2 = AVDSX_fp2 * Vds_fp2;
    if (T0_fp2 > `EXPL_THRESHOLD) begin
       T1_fp2 = T0_fp2;
    end else begin
       T1_fp2 = ln(1.0 + exp(T0_fp2));
    end
    Vdsx_fp2 = ((2.0/AVDSX_fp2) * T1_fp2) - Vds_fp2 - ((2.0/AVDSX_fp2) * ln(2.0));
    Vbsx_fp2 = -(Vs_fp2 + 0.5 * (Vds_fp2 - Vdsx_fp2));

$strobe(">- DOS_2D_fp2 = %g V \t Vds_fp2 = %g V \t T1_fp2 = %g V \t Vdsx_fp2 = %g V \t Vbsx_fp2 = %g V \t",
        DOS_2D_fp2, Vds_fp2, T1_fp2, Vdsx_fp2, Vbsx_fp2);
//
//***********************************************
// 
// SCE, DIBL, SS degradation effects for FP2
//
//***********************************************
// 
    `Smooth(Phist_fp2 - Vbsx_fp2, 0.05, 0.1, PhistVbs_fp2)
    sqrtPhistVbs_fp2 = sqrt(PhistVbs_fp2);
    Xdep_fp2 = T1DEP_fp2 * sqrtPhistVbs_fp2;
    Cdep_fp2 = ep_GaN_fp2 / Xdep_fp2;

    cdsc_fp2 = CIT_fp2 + NFACTOR_fp2 + CDSCD_fp2 * Vdsx_fp2 - CDSCB_fp2 * Vbsx_fp2;
    T1_fp2 = 1.0 + cdsc_fp2 / cb_fp2;
    `Smooth(T1_fp2, 1, 0.05, n_fp2)

    nUT_fp2 = n_fp2 * UT_fp2;
    inv_nUT_fp2 = 1.0 / nUT_fp2;

    vd_fp2 = Vd_fp2 * inv_nUT_fp2;
    vg_fp2 = Vg_fp2 * inv_nUT_fp2;
    vs_fp2 = Vs_fp2 * inv_nUT_fp2;
    vA_fp2 = VA_fp2 * inv_nUT_fp2;
//
//***********************************************
// 
// Vth Shift for DIBL (FP2)
//
//***********************************************
// 
    dVth_dibl_fp2 = -(ETA0_fp2 + ETAB_fp2 * Vbsx_fp2) * Vdsx_fp2;
    Vth_shift_fp2 = dVth_dibl_fp2;
    vg_vA_fp2 = vg_fp2 - vA_fp2 - Vth_shift_fp2 * inv_nUT_fp2;

    gam_fp2 = sqrt(2.0 * q_fp2 * ep_GaN_fp2 * NDEP_fp2 * inv_UT_fp2) / cb_fp2;
    inv_gam_fp2 = 1 / gam_fp2;
    phib_n_fp2 = phib_fp2 / n_fp2;

`pinch_norm(vg_vA_fp2, gam_fp2, pinch_n_fp2)
`Smooth(pinch_n_fp2, 1.0, 2.0, pinch_norm_cl_fp2)

   sqrtpsip_fp2 = sqrt(pinch_norm_cl_fp2);
   n_q_fp2 = 1 + gam_fp2 / (2 * sqrt(pinch_norm_cl_fp2));
   Qsp_fp2 = 2 * n_q_fp2 * cb_fp2 * UT_fp2;

   dat_fp2 = gg_fp2 / UT_fp2;
   beta_fp2 = dat_fp2 * n0_fp2 ** (0.6666);
   v_s_fp2 = ln(NDEP_fp2 / NV_fp2) + EgGaN_fp2 / (q_fp2 * UT_fp2);

   qs_fp2 = core(vs_fp2, pinch_n_fp2, n_q_fp2, gam_fp2, cb_fp2, DOS_2D_fp2, gg_fp2, UT_fp2, v_s_fp2, phib_fp2);
//
//***********************************************
// 
// source side surface potential
//
//***********************************************
// 
 psiavg_fp2 = pinch_n_fp2 - 2.0 * qs_fp2;
   `Smooth(psiavg_fp2, 1.0, 2.0, T0_fp2);
   nq_fp2 = 1.0 + gam_fp2 / (sqrtpsip_fp2 + sqrt(T0_fp2));

   EeffF_fp2 = cb_fp2 / (E0_t_fp2 * ep_GaN_fp2);
   T0_fp2 = nUT_fp2 * (vg_vA_fp2 - pinch_n_fp2 - 2.0 * qs_fp2 * (nq_fp2 - 1.0));
   `Smooth(T0_fp2, 0, 0.1, qbs_fp2);

   // Source side qi and qb for Vdsat (FP2)
   qis_fp2 = 2.0 * nq_fp2 * nUT_fp2 * qs_fp2;
   Eeffs_fp2 = EeffF_fp2 * (qbs_fp2 + eta_mu_fp2 * qis_fp2);

   // Mobility model (FP2)
   T2_fp2 = pow(0.5 * (1.0 + (qis_fp2 / qbs_fp2)), USC_fp2);
   T3_fp2 = (UA_fp2 + UC_fp2 * Vbsx_fp2) * pow(Eeffs_fp2, EU_fp2) + UD_fp2 / T2_fp2;
   T4_fp2 = 1.0 + T3_fp2;
   `Smooth(T4_fp2, 1.0, 0.0015, Vmr_fp2);

   UCRIT_T_fp2 = UCRIT_fp2 * pow(TRatio_fp2, -UCEX_fp2);
//
//***********************************************
// 
// Saturation Voltage (FP2)
//
//***********************************************
// 
   vp_fp2 = pinch_n_fp2 - phib_fp2;

//
//***********************************************
// 
// FP2 VELOCITY SATURATION & CHANNEL LENGTH MODULATION 
//
//***********************************************
// 
    g_clm_fp2 = 0.1;
    e_clm_fp2 = 2.0 * nUT_fp2 / (UCRIT_T_fp2 * L_fp2);

    e_clm2_fp2 = e_clm_fp2 * e_clm_fp2;
    e_clmx2_fp2 = 2.0 * e_clm_fp2;
    e_clmp2_fp2 = 2.0 + e_clm_fp2;
    e_clmx2xqs_fp2 = e_clmx2_fp2 * qs_fp2;

    qdsat_fp2 = e_clmx2_fp2 * (qs_fp2**2 + qs_fp2) /
                (e_clmp2_fp2 + e_clmx2xqs_fp2 + sqrt(e_clmp2_fp2 * e_clmp2_fp2 + 4.0 * e_clmx2xqs_fp2));

    qs_qsat_fp2 = qs_fp2 - qdsat_fp2;
    qs_qsat2_fp2 = qs_qsat_fp2 * qs_qsat_fp2;

    mdm2_fp2 = 2.0 - DELTA_fp2;

    e_clmxmdm2_2_fp2 = e_clm2_fp2 * mdm2_fp2 * mdm2_fp2;

    tmp_vdsat1_fp2 = (2.0 * qdsat_fp2 + ln(qdsat_fp2)) * (1.0 + e_clm_fp2 * qs_qsat_fp2);
    tmp_vdsat11_fp2 = g_clm_fp2 + e_clm_fp2 * mdm2_fp2 * qs_qsat_fp2;
    tmp_vdsat2_fp2 = sqrt(1.0 + (2.0 * e_clm2_fp2 * mdm2_fp2 * mdm2_fp2 * qs_qsat2_fp2) / tmp_vdsat11_fp2
                            + e_clm2_fp2 * qs_qsat2_fp2);

    vdsat_fp2 = vp_fp2 - tmp_vdsat1_fp2 / tmp_vdsat2_fp2;
	
//
//***********************************************
// // -- VELOCITY SATURATION (DEPENDENT ON VD) - FP2
//
//***********************************************
//   dv_clm_fp2 = (ACLM_fp2 / DELTA_fp2) * (4.0 * qdsat_fp2 + DELTA_fp2) / (qs_fp2 + 1.0);

  tmp_vdp1_fp2 = (vd_fp2 - vs_fp2) * sqrt(1.0 + 4.0 * dv_clm_fp2 / vdssat_fp2);
  tmp_vdp2_fp2 = sqrt((tmp_vdp1_fp2 + vdssat_fp2) * (tmp_vdp1_fp2 + vdssat_fp2) + 4.0 * dv_clm_fp2 * vdssat_fp2);
  tmp_vdp3_fp2 = sqrt((tmp_vdp1_fp2 - vdssat_fp2) * (tmp_vdp1_fp2 - vdssat_fp2) + 4.0 * dv_clm_fp2 * vdssat_fp2);

  vdp_fp2 = 0.5 * (tmp_vdp2_fp2 - tmp_vdp3_fp2) + vs_fp2;
//
//***********************************************
// NOTE: The potential at the velocity saturated point of the channel (FP2)
//
//***********************************************
// 
// -- CHANNEL LENGTH MODULATION - FP2
//
//***********************************************
// 
  u_clm_fp2 = 0.5 * e_clm_fp2 * Leff_fp2 / LC_fp2 * (vd_fp2 - vdp_fp2);
  alpha_clm_fp2 = LC_fp2 / (Leff_fp2 - 2.0 * LC_fp2);

  deltal_fp2 = LAMBDA_fp2 * LC_fp2 * ln((alpha_clm_fp2 + u_clm_fp2 +
               sqrt(u_clm_fp2 * u_clm_fp2 + 2.0 * alpha_clm_fp2 * u_clm_fp2 + 1.0)) /
               (alpha_clm_fp2 + 1.0));

//
//***********************************************
// 
// CALCULATION OF NORMALIZED INVERSION CHARGE AT VELOCITY SATURATED POINT (FP2)
//
//***********************************************
// 
  qdeff_fp2 = core(vdp_fp2, pinch_n_fp2, nq_fp2, gam_fp2, cb_fp2, DOS_2D_fp2, gg_fp2, UT_fp2, v_s_fp2, phib_fp2);

  psiavg_fp2 = pinch_n_fp2 - qs_fp2 - qdeff_fp2;
  `Smooth(psiavg_fp2, 1.0, 2.0, T0_fp2);
  T2_fp2 = sqrt(T0_fp2);
  nq_fp2 = 1.0 + gam_fp2 / (sqrtpsip_fp2 + T2_fp2);

//
//***********************************************
// 
// Inversion and bulk charge (FP2)
//
//***********************************************
// 
  DQSD2_fp2 = (qs_fp2 - qdeff_fp2) * (qs_fp2 - qdeff_fp2);
  T0_fp2 = 1.0 / (1.0 + qs_fp2 + qdeff_fp2);
  T1_fp2 = DQSD2_fp2 * T0_fp2;

  Qb_fp2 = vg_vA_fp2 - pinch_n_fp2 - (nq_fp2 - 1.0) * (qs_fp2 + qdeff_fp2 + `Oneby3 * T1_fp2);

  T2_fp2 = `Oneby3 * nq_fp2;
  T3_fp2 = T1_fp2 * T0_fp2;

  Qs_fp2 = T2_fp2 * (2.0 * qs_fp2 + qdeff_fp2 + 0.5 * (1.0 + 0.8 * qs_fp2 + 1.2 * qdeff_fp2) * T3_fp2);
  Qd_fp2 = T2_fp2 * (qs_fp2 + 2.0 * qdeff_fp2 + 0.5 * (1.0 + 1.2 * qs_fp2 + 0.8 * qdeff_fp2) * T3_fp2);

//
//***********************************************
// 
// Mobility degradation - Average charges (FP2)
//
//***********************************************
// 
  `Smooth(nUT_fp2 * Qb_fp2, 0, 0.1, qba_fp2);
  qia_fp2 = nUT_fp2 * (Qs_fp2 + Qd_fp2);

  Eeffm_fp2 = EeffF_fp2 * (qba_fp2 + eta_mu_fp2 * qia_fp2);

  T2_fp2 = pow(0.5 * (1.0 + (qia_fp2 / qba_fp2)), USC_fp2);
  T3_fp2 = (UA_fp2 + UC_fp2 * Vbsx_fp2) * pow(Eeffm_fp2, EU_fp2) + UD_fp2 / T2_fp2;
  T4_fp2 = 1.0 + T3_fp2;
  `Smooth(T4_fp2, 1.0, 0.0015, Vmr_fp2);

//
//***********************************************
// 
// Final Dvsat & Effective mobility (FP2)
// 
//***********************************************
// 
  qsqdp_fp2 = qs_fp2 + qdeff_fp2;
  qs_qdp_fp2 = qs_fp2 - qdeff_fp2;
  powqs_qdp2_fp2 = qs_qdp_fp2 * qs_qdp_fp2;
  qsqdpp1_fp2 = qsqdp_fp2 + 1.0;

  Dvsat_fp2 = sqrt(1.0 + 4.0 * e_clmxmdm2_2_fp2 * powqs_qdp2_fp2 /
              (g_clm_fp2 + e_clm_fp2 * mdm2_fp2 * (qs_qdp_fp2)) + e_clm2_fp2 * powqs_qdp2_fp2);

  Dr_fp2 = 1.0;
  Dtot_fp2 = Vmr_fp2 * Dvsat_fp2 * Dr_fp2;
//
//***********************************************
// 
// Effective mobility
//
//***********************************************
// 
  ueff_fp2 = mut_fp2 / Dtot_fp2;

  Isp_fp2 = 2.0 * NF_fp2 * nq_fp2 * ueff_fp2 * W_fp2 / (Leff_fp2 - deltal_fp2) *
            cb_fp2 * nUT_fp2 * nUT_fp2;

//
//***********************************************
// Final Current & Derivatives (FP2)
//
//***********************************************
// 
  idsout_fp2 = Isp_fp2 * ((qs_fp2 - qdeff_fp2) * (1.0 + qs_fp2 + qdeff_fp2));

  // (Optional derivatives - commented style from original)
  // T1_fp2 = q_fp2 / (nq_fp2 * Qsp_fp2); ...
  // Gm_fp2, Gds_fp2, etc.

  calc_Ids_fp2 = idsout_fp2; // or lc_Ids_fp2 depending on your naming
  
  
//***********************************************
// 
// S/D Series Resistance
//series resistance
//
//***********************************************
// 
real nsacc, vsatacc, muacc, qacc;
real Rd0,Rs0,Rd,Rs,Rcos,Rcod;
real Iaccs,Iaccd;
real Vcrits,Vcritd;
 real  leff, leffs, leffd, lefffp1;
real VDAR,VSAR;
real phibb;
real Cb;
//
//***********************************************
// 
// Material Parameters 
real EgGaN,EgAlN,EgAlGaN;
real ep_AlGaN, Ef_AlGaN,DOS_2D,ni_gan;
real  UT, inv_UT;
 real phistt;
 real T1DEP;
// Vertical Field 
real eta_mu,E0_t;
//
//***********************************************
// 
// charge variables
real tambk, tsh, tdut, pdiss, mut, TRatio;
//
//***********************************************
// 
 real Dvsat,Dr;

 //real  difqdeff_VG,difqs_VG,difqdeff_VD,Gm,Gds;	
 real ueff,ids,IDS;

  real dir, dirfp1;
  real vdsi, vgsi,vsi,vdi,vgi,vdsrd,vgsfp1,vdsfp1,vcfp1,vbfp1;
  real idsfp1;
//real itfp,iti;
real vsfp1,vdfp1,vgfp1,vfp1,vdi1,vsi1;
real gmi,gdsi,gmfp1,gdsfp1,T0,T1,T2,Rd1,Rs1;
   real rd, rs, rg;
//
//******************ac*****************************
// 
analog begin
	  leff=L;
      leffs           = LGS ;
      leffd           = LSFPD ;
      lefffp1         = lgfp1;
      DOS_2D=0.2*me/((1/q)*pi*(1.05459e-34)**2);
      tambk              = $temperature;
      tsh                = Temp(t);
      tdut               = tambk + tsh;

      TRatio     = tdut / TNOM;
      UT = 0.0259*(tdut/TNOM);
$strobe(">- tambk = %g V \t tsh = %g V \t tdut = %g V \t UT = %g V \t", tambk, tsh, tdut, UT);
//
//***********************************************
// 
       EgGaN = 3.507*q-(0.909e-3)*tdut**2/(tdut+830)*q; //Joule
       EgAlN = 6.23*q-(1.799e-3)*tdut**2/(tdut+1462)*q; //Joule
       EgAlGaN= EgAlN*xx+EgGaN*(1-xx)*1.3*xx*(1-xx)*q; //Joule
       ep_AlGaN=(8.5*xx+8.9*(1-xx))*`EP0;
       Ef_AlGaN =0*q;
	   // Mobility degradation
       eta_mu = (TYPE != `type_n) ? (0.3333) : (0.5); 
	   mut   = U0 * pow(TRatio, BEX);
	   E0_t=E0*pow(TRatio, DE0);
	  inv_UT=1/UT;
   	ni_gan=sqrt(NC_GaN*NV)*exp(-EgGaN/(2*q*UT));
     phibb=lln(NDEP/(ni_gan));
     phistt     = max(0.4 + UT * phibb + PHIN, 0.4);
	 T1DEP     = sqrt(2.0 * ep_GaN / (q * NDEP));
	 Cb=ep_AlGaN/x1;
	 $strobe(">- phistt = %g V \t Cb = %g V \t phibb = %g V \t ", phistt, Cb,phibb);
//
//***********************************************
// 
  // Determines source for intrinsic transistor
     rg                 = ( rgsp / W / NF);
  nsacc=ns0;
	 vsatacc=vsat0acc*(1-kth1*(TRatio-1))**kth2;
	 muacc=mu0acc*pow(TRatio, kth3);
	 qacc=q*nsacc*W;
  	 VDAR=V(d,fp1);
	  Rd0=leffd/(W*qacc*muacc)*(1-kth1*(TRatio-1));
	  Vcritd=vsatacc/muacc*leffd;
	  Rcod=Rcd/W;
	  Rd=Rcod*(1+ktrd*pow(TRatio,1));
	    T0=0;
	 T1=0;
	 T2=0;
	     T0=VDAR/Vcritd;
     T1=pow(T0,gsar);
	 T2=pow(1+T1,1/gsar);
    Rd1=Rd0*T2;	 
	Iaccd=VDAR/Rd1;
  I(d,fp2)          <+V(d,fp2)/Rd1;
  $strobe(">- idfp1 = %g V \t T0 = %g V \t T1 = %g V \t T2 = %g V \t ",  I(d,fp1) , T0 , T1 , T2);
  dirfp1          = sd_dir(vgsfp1,vdsfp1,type,V(g,di),V(g,fp1),V(fp1,di)); 
  idsfp1          = calc_Ids(V(fp1,b),V(g,b),V(di,b),vtofp1,Cb,phistt,UT,phibb,lgfp1); 
  I(fp1,di)       <+ calc_Ids(V(fp1,b),V(gi,b),V(di,b),vtofp1,Cb,phistt,UT,phibb,lgfp1) ;
    dir = sd_dir(vgsi,vdsi,type,V(g,si),V(g,di),V(di,si)); 
	 	 $strobe(">- idsfp1 = %g V \t  ", I(fp1,di) );

I(d,fp2)          <+V(d,fp2)/Rd1;
  $strobe(">- idfp1 = %g V \t T0 = %g V \t T1 = %g V \t T2 = %g V \t ",  I(d,fp1) , T0 , T1 , T2);
  dirfp2          = sd_dir(vgsfp2,vdsfp2,type,V(s,fp1),V(s,fp2),V(fp2,fp1)); 
  idsfp2          = calc_Ids(V(fp2,b),V(s,b),V(fp1,b),vtofp2,CBFP2,phistt,UT,phibb,lgfp2); 
  I(fp2,fp1)       <+ calc_Ids(V(fp2,b),V(s,b),V(fp1,b),vtofp2,Cb,phistt,UT,phibb,lgfp1) ;
    dir = sd_dir(vgsi,vdsi,type,V(g,si),V(g,di),V(di,si)); 
	 	 $strobe(">- idsfp1 = %g V \t  ", I(fp1,di) );
/////////////////////////
	 //$strobe(">- ids = %g V \t  ", ids);
   I(di,si)           <+ calc_Ids(V(di,b),V(gi,b),V(si,b),vto,Cb,phistt,UT,phibb,leff) ;
   VSAR=V(si,s);
	 $strobe(">- VDAR = %g V \t VSAR = %g V \t  ", VDAR, VSAR);
 //
//***********************************************
// 
	 Rs0=leffs/(W*qacc*muacc)*(1-kth1*(TRatio-1));
	 Vcrits=vsatacc/muacc*leffs;
	  T0=0;
	 T1=0;
	 T2=0;
     T0=VSAR/Vcrits;
     T1=pow(T0,gsar);
	 T2=pow(1+T1,1/gsar);
    Rs1=Rs0*T2;
      I(si,s)          <+V(si,s)/Rs1;
	 //fp1,vbfp1,flagfp1s,dirfp1,tdut,tnomk,phit,weff,lefffp1,cgfp1,cfp1s,ccfp1,cbfp1,vtofp1,sfp1,delta1fp1,0.0,ndfp1,alphafp1,vx0fp1,mu0fp1,betafp1,mthetafp1,vthetafp1,vtzeta,dibsat,epsilon,vzeta,lambda,ngf,type);
   $strobe(">- isis = %g V \t T0 = %g V \t T1 = %g V \t T2 = %g V \t ",  I(si,s) , T0 , T1 , T2);

vgsfp1=V(g,di);
vdsfp1=V(fp1,di); 
vgsi=V(g,si);
vdsi=V(di,si); 
vfp1=V(fp1,b);
vdi1=V(di,b);
vsi1=V(si,b);
vgsfp2=V(s,fp1);
vdsfp1=V(fp2,fp1); 

$strobe(">- vgsfp1 = %g V \t vdsfp1 = %g V \t vfp1 = %g V \t ", V(g,di),V(fp1,di),V(fp1,b)); 
	 $strobe(">- vgsi = %g V \t vdsi = %g V \t vdi = %g V \t vsi = %g V \t ", V(g,si), V(di,si),V(di,b),V(si,b));

   if (rg < minr) begin
      V(g,gi)         <+ 0;
   end else begin
     I(g,gi)          <+  V(g,gi) / rg;
   end
   idsfp1          = calc_Ids(idsfp1,qgsfp1,qgdfp1,qcfp1,vdfp1,vsfp1,vgfp1,0,vtofp1,cbfp1,pinch_n,phistt,UT,phibb); fp1,vbfp1,flagfp1s,dirfp1,tdut,tnomk,phit,weff,lefffp1,cgfp1,cfp1s,ccfp1,cbfp1,vtofp1,sfp1,delta1fp1,0.0,ndfp1,alphafp1,vx0fp1,mu0fp1,betafp1,mthetafp1,vthetafp1,vtzeta,dibsat,epsilon,vzeta,lambda,ngf,type);
   	 

 ids                = 0;
 ids                = calc_Ids(ids,qgs,qgd,qc,vdi,vsi,vgi,0,vto,cbfp1,pinch_n,phistt,UT,phibb);//0,0,0,dir,tdut,tnomk,phit,weff,leff,cg,0,0,0,vto,ss,delta1,delta2,nd,alpha,vx0,mu0,beta,mtheta,vtheta,vtzeta,dibsat,epsilon,vzeta,lambda,ngf,type);

     I(di,si)           <+ ids ;
  
     VDAR=V(d,fp1);
	 
	 Iaccd=access(Rd0,Vcritd,VDAR,gsar);
	 Iaccs=access(Rs0,Vcrits,VSAR,gsar);
Rcos=Rcs/W;	  
 Rs=Rcos*(1+ktrs*pow(TRatio,1));
 V(gi)<+   V(g);
 V(gfp)<+   V(g);
 I(si,s)          <+ Iaccs;
I(d,fp1)          <+ Iaccd;
Dr=1;
Dr      = 1.0 + U0 /(Dvsat * Vmr) * Cb * W / (leff-deltal) * qia * (Rs+Rd);
$strobe(">- VDAR = %g V \t VSAR = %g V \t Vcritd = %g V \t ", VDAR, VSAR,Vcritd);

//
//***********************************************
// 
// Self-heating
//
//***********************************************
// 
   if (rth !=0) begin
 
      pdiss            = -( I(di,si) * V(di,si)+ I(d,fp1) * V(d,fp1) + I(si,s) * V(si,s) + I(fp1,di) * V(fp1,di));
      Pwr(t)          <+ ddt( (cth ) * Temp(t));
      Pwr(t)          <+ pdiss;
      Pwr(t)          <+ Temp(t) / rth;
   end
   else
      Pwr(t)          <+ Temp(t) * 1e9;

end
   
endmodule
